rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'ADMIN';
    }

    function isSeller() {
      return isSignedIn() && getUserRole() == 'SELLER';
    }

    function isBuyer() {
      return isSignedIn() && getUserRole() == 'BUYER';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isListingOwner(listingId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/listings/$(listingId)).data.ownerId == request.auth.uid;
    }

    function isListingApproved(listing) {
      return listing.status == 'approved';
    }

    function isAdminFieldModified() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'status', 
        'badge', 
        'badgeAssignedAt',
        'badgeAssignedBy',
        'adminReviewedAt', 
        'adminNotes', 
        'rejectionReason',
        'aiRiskScore',
        'suggestedBadge',
        'suggestedBadgeReason'
      ]);
    }

    // ============================================
    // USER PROFILES
    // ============================================

    match /users/{userId} {
      // Users can read their own profile; admins can read any profile for moderation
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can modify their own profile data (excluding role)
      allow write: if isOwner(userId) && 
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'createdAt', 'updatedAt']);

      // Subcollection: User's favorited listings
      match /favorites/{listingId} {
        allow read, write, delete: if isOwner(userId);
      }
      
      // Subcollection: User's saved searches
      match /savedSearches/{searchId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    // ============================================
    // LISTINGS
    // ============================================

    match /listings/{listingId} {
      let listing = resource.data;
      let incoming = request.resource.data;

      // READ: Approved listings visible to all signed-in users and public.
      // Non-approved listings visible only to owner (seller) and admins.
      allow get: if isListingApproved(listing) || 
                    (isSignedIn() && (isListingOwner(listingId) || isAdmin()));
      
      // LIST: Public listing queries must filter by status='approved'.
      // Admins and sellers can see their own/all listings based on role.
      allow list: if isAdmin() || 
                    (isSignedIn() && isSeller() && query.where('ownerId', '==', request.auth.uid)) ||
                    (request.query.limit <= 50 && listing.status == 'approved');

      // CREATE: Sellers and admins can create listings.
      // New listing must be in 'pending' status (not auto-approved).
      allow create: if isSignedIn() && 
                      (isSeller() || isAdmin()) &&
                      incoming.ownerId == request.auth.uid &&
                      incoming.status == 'pending' &&
                      incoming.createdAt == request.time &&
                      incoming.updatedAt == request.time;

      // UPDATE: 
      // - Sellers can update their own listings, but NOT admin-only fields
      // - Admins can update any listing, including admin-only fields (status, badge, notes)
      allow update: if isSignedIn() && (
        // Admin: can modify everything
        isAdmin() ||
        // Seller: can only modify their own listings (not admin fields)
        (isListingOwner(listingId) && !isAdminFieldModified() && isSeller())
      ) && incoming.updatedAt == request.time;

      // DELETE: Only sellers can delete their own pending listings. 
      // Admins can delete any listing (for cleanup/moderation).
      allow delete: if isSignedIn() && (
        (isListingOwner(listingId) && isSeller() && listing.status == 'pending') ||
        isAdmin()
      );

      // Subcollection: Evidence documents for this listing
      match /evidence/{evidenceId} {
        let evidence = resource.data;
        let incomingEvidence = request.resource.data;

        // READ: Only listing owner and admins can read evidence
        allow read: if isSignedIn() && (isListingOwner(listingId) || isAdmin());
        
        // CREATE: Only listing owner can add evidence to their own listings
        allow create: if isSignedIn() && 
                        isListingOwner(listingId) &&
                        isSeller() &&
                        incomingEvidence.ownerId == request.auth.uid &&
                        incomingEvidence.createdAt == request.time;
        
        // UPDATE: Minimal updates (e.g., OCR completion). Admin can update for manual corrections.
        allow update: if isSignedIn() && (
          (isListingOwner(listingId) && isSeller() && 
           !incomingEvidence.diff(evidence).affectedKeys().hasAny(['storagePath', 'checksum', 'ownerId'])) ||
          isAdmin()
        );
        
        // DELETE: Seller can delete their own evidence; admins can delete any
        allow delete: if isSignedIn() && (
          (isListingOwner(listingId) && isSeller()) ||
          isAdmin()
        );
      }
    }

    // ============================================
    // EVIDENCE (Top-level, for direct access)
    // ============================================

    match /evidence/{evidenceId} {
      let evidence = resource.data;
      let listing = get(/databases/$(database)/documents/listings/$(evidence.listingId)).data;

      // READ: Listing owner and admins only
      allow read: if isSignedIn() && (
        listing.ownerId == request.auth.uid ||
        isAdmin()
      );

      // CREATE: Only listing owner can create
      allow create: if isSignedIn() && 
                      request.resource.data.ownerId == request.auth.uid &&
                      isSeller() &&
                      request.resource.data.createdAt == request.time;

      // UPDATE: Seller updates, admin overrides
      allow update: if isSignedIn() && (
        (listing.ownerId == request.auth.uid && isSeller()) ||
        isAdmin()
      );

      // DELETE: Seller or admin only
      allow delete: if isSignedIn() && (
        (evidence.ownerId == request.auth.uid && isSeller()) ||
        isAdmin()
      );
    }

    // ============================================
    // CONVERSATIONS & MESSAGING
    // ============================================
    
    match /conversations/{conversationId} {
      let conversation = resource.data;

      // Participants can read, list, and update their conversations
      allow get, list, update: if isSignedIn() && request.auth.uid in conversation.participantIds;
      
      // Participants can create conversations they're part of
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      
      // Only admins can delete conversations (moderation)
      allow delete: if isAdmin();

      // Subcollection: Messages in conversation
      match /messages/{messageId} {
        let message = resource.data;
        let participants = get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        // Conversation participants can read messages
        allow read: if isSignedIn() && request.auth.uid in participants;
        
        // Only conversation participants can send messages
        allow create: if isSignedIn() && 
                        request.auth.uid in participants &&
                        request.resource.data.senderId == request.auth.uid &&
                        request.resource.data.createdAt == request.time;
        
        // Users can delete their own messages; admins can delete any
        allow delete: if isSignedIn() && (
          (message.senderId == request.auth.uid) ||
          isAdmin()
        );
      }
    }

    // ============================================
    // CONTACT FORM SUBMISSIONS
    // ============================================

    match /contactMessages/{messageId} {
      // Public can submit contact form
      allow create: if request.resource.data.submittedAt == request.time;
      
      // Only admins can read, update, delete
      allow read, update, delete: if isAdmin();
    }
    
    // ============================================
    // LISTING REPORTS (Moderation)
    // ============================================

    match /listingReports/{reportId} {
      // Public can report listings
      allow create: if request.resource.data.createdAt == request.time;
      
      // Only admins can view, update status, delete
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // EMAIL QUEUE (Internal)
    // ============================================

    match /emailQueue/{msgId} {
      // Only admins can read/create (internal queue management)
      allow read, create: if isAdmin();
      
      // Queue items are immutable (no updates/deletes)
      allow update, delete: if false;
    }

    // ============================================
    // AUDIT LOGS (Immutable, append-only)
    // ============================================

    match /auditLogs/{logId} {
      // Only admins can read/create audit logs
      allow read, create: if isAdmin();
      
      // Audit logs are immutable (no modifications or deletions)
      allow update, delete: if false;
    }

    // ============================================
    // ADMIN CONFIGURATION
    // ============================================

    match /adminConfig/{configDoc} {
      // All users can read global settings (e.g., feature flags, SLAs)
      allow read: if true;
      
      // Only admins can write configuration
      allow write: if isAdmin();
    }

    // ============================================
    // NEWSLETTER SUBSCRIBERS
    // ============================================

    match /newsletterSubscribers/{subId} {
      // Public can subscribe
      allow create: if request.resource.data.subscribedAt == request.time;
      
      // Only admins can manage subscribers
      allow read, update, delete: if isAdmin();
    }
  }
}
