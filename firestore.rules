rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KENYA LAND TRUST - SECURITY RULES DOCUMENTATION
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a multi-tier security model involving strict ownership, administrative 
     * overrides, and public visibility for verified listings. It utilizes "Authorization Independence" 
     * through data denormalization to minimize cross-document lookups (get() calls).
     *
     * DATA STRUCTURE:
     * - /adminRoles/{userId}: DBAC (Database Access Control) mapping for global administrators.
     * - /userProfiles/{userId}: Private user information.
     * - /userProfiles/{userId}/draftListings/{listingId}: Private workspace for sellers' incomplete listings.
     * - /listings/{listingId}: Top-level collection for public or reviewed listings.
     * - /listings/{listingId}/...: Subcollections for evidence, badges, signals, and summaries.
     *
     * KEY SECURITY DECISIONS:
     * 1. DBAC for Admin: Administrative privileges are determined by the existence of a document 
     *    in the /adminRoles collection, providing a performant "existence over content" check.
     * 2. Structural Segregation: Drafts are stored in a user-scoped path to prevent accidental 
     *    exposure, while active listings are in a flat root collection for optimized querying.
     * 3. Denormalization for Authorization: Essential IDs (like sellerId) are copied into 
     *    sub-documents to allow rules to verify access without reading parent documents.
     * 4. Relational Integrity: On creation and update, rules ensure that ownership fields 
     *    cannot be spoofed or transferred.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user owns the existing document via an internal field
    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    // Ensures a newly created or updated document correctly attributes ownership
    function isValidOwnership(ownerIdField) {
      return request.resource.data[ownerIdField] == request.auth.uid;
    }

    // Ensures a field does not change during an update
    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    /**
     * @description Administrative roles used for global authorization overrides.
     * @path /adminRoles/{userId}
     * @allow (get) Any signed-in user to check existence; (list, write) Admin only.
     * @deny (write) Non-admins attempting to promote themselves.
     * @principle DBAC pattern for efficient global role management.
     */
    match /adminRoles/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description User profiles containing personal details and roles.
     * @path /userProfiles/{userId}
     * @allow (get, list, write) User matching the userId or an Admin.
     * @deny (get) One user trying to read another user's private profile.
     * @principle Path-based ownership matching authenticated UID.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && isImmutable('userRole')) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Draft listings strictly private to the creating seller.
     * @path /userProfiles/{userId}/draftListings/{listingId}
     * @allow (get, list, write) The seller identified in the path or an Admin.
     * @deny (get, list) Public users or other sellers.
     * @principle Structural segregation of private drafts from public listings.
     */
    match /userProfiles/{userId}/draftListings/{listingId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.sellerId == userId;
      allow update: if (isOwner(userId) && isImmutable('sellerId')) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    /**
     * @description Publicly viewable or active listings.
     * @path /listings/{listingId}
     * @allow (get, list) Public if active/not suspicious; (write) Seller or Admin.
     * @deny (update) Seller trying to change the sellerId of a listing.
     * @principle Owner-based writes with conditional public reads.
     */
    match /listings/{listingId} {
      allow get, list: if (resource.data.status == 'Active' && resource.data.isSuspicious == false) || isExistingOwner('sellerId') || isAdmin();
      allow create: if isSignedIn() && isValidOwnership('sellerId');
      allow update: if (isExistingOwner('sellerId') && isImmutable('sellerId')) || isAdmin();
      allow delete: if isExistingOwner('sellerId') || isAdmin();
    }

    /**
     * @description Supporting documents for land listings.
     * @path /listings/{listingId}/evidenceDocuments/{evidenceDocumentId}
     * @allow (get, list) The listing seller or an Admin.
     * @deny (create) User trying to upload evidence for a listing they don't own.
     * @principle Denormalization of listingSellerId for independent authorization.
     */
    match /listings/{listingId}/evidenceDocuments/{evidenceDocumentId} {
      allow get, list: if isExistingOwner('listingSellerId') || isAdmin();
      allow create: if isSignedIn() && isValidOwnership('listingSellerId');
      allow update: if (isExistingOwner('listingSellerId') && isImmutable('listingSellerId')) || isAdmin();
      allow delete: if isExistingOwner('listingSellerId') || isAdmin();
    }

    /**
     * @description Verification badges assigned to listings.
     * @path /listings/{listingId}/trustBadges/{badgeId}
     * @allow (get, list) Public; (write) Admin only.
     * @deny (write) Sellers attempting to give themselves badges.
     * @principle Public read-only data managed exclusively by administrators.
     */
    match /listings/{listingId}/trustBadges/{badgeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Flags for suspicious activity or patterns.
     * @path /listings/{listingId}/suspiciousSignals/{signalId}
     * @allow (get, list) Admin or the seller of the associated listing.
     * @deny (write) Sellers attempting to delete or resolve their own signals.
     * @principle Restricts resolution and management of flags to administrators.
     */
    match /listings/{listingId}/suspiciousSignals/{signalId} {
      allow get, list: if isExistingOwner('listingSellerId') || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description AI-generated summaries of evidence documents.
     * @path /listings/{listingId}/evidenceDocuments/{evidenceDocumentId}/evidenceSummaries/{summaryId}
     * @allow (get, list) Admin or the listing seller.
     * @deny (create) Any manual creation by non-admins.
     * @principle Grandparent-level denormalization (listingSellerId) for access.
     */
    match /listings/{listingId}/evidenceDocuments/{evidenceDocumentId}/evidenceSummaries/{summaryId} {
      allow get, list: if isExistingOwner('listingSellerId') || isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}